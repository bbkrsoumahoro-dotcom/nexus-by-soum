def jload(fp, default=None):
    if default is None: default = {}
    try:
        if os.path.exists(fp):
            with open(fp, encoding="utf-8") as f: return json.load(f)
    except: pass
    return default

def jsave(fp, data):
    with open(fp, "w", encoding="utf-8") as f: json.dump(data, f, indent=2)

if not os.path.exists(CONFIG_FILE):
    jsave(CONFIG_FILE, {"site_name":"NEXUS ULTIMATE v4.0", "allow_registration":True, "ai_api_key":""})
