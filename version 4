function renderCloud(m){
  m.innerHTML='<div class="title">Cloud <button class="btn btn-primary" onclick="document.getElementById(\'fu\').click()">Upload</button></div><input type="file" id="fu" style="display:none" onchange="upFile(this)"><div id="cl"></div>';
  listCloud();
}

function upFile(inp){
  if(!inp.files||!inp.files[0])return;
  var fd=new FormData();fd.append("file",inp.files[0]);
  fetch("/api/cloud/upload",{method:"POST",headers:{Authorization:"Bearer "+S.token},body:fd})
  .then(function(r){return r.json()}).then(function(d){if(d.success){toast("Upload OK");listCloud()}});
}

function listCloud(){
  fetch("/api/cloud/list",{headers:{Authorization:"Bearer "+S.token}}).then(function(r){return r.json()}).then(function(f){
    var c=document.getElementById("cl");
    if(!f||!f.length){c.innerHTML='<div class="empty">Cloud vide</div>';return}
    var h="<div class='grid'>";
    for(var i=0;i<f.length;i++){
      h+='<div class="card"><div class="icon">&#128196;</div><div class="name">'+f[i].name+'</div>';
      h+='<div style="color:#888;font-size:.8rem">'+fmt(f[i].size)+'</div>';
      h+='<div class="flex" style="justify-content:center;margin-top:8px">';
      h+='<button class="btn btn-primary" onclick="window.open(\'/api/cloud/download/'+f[i].name+'\')">DL</button>';
      h+='<button class="btn btn-danger" onclick="delCloud(\''+f[i].name+'\')">X</button></div></div>';
    }
    h+="</div>";c.innerHTML=h;
  });
}

function delCloud(n){
  if(!confirm("Supprimer?"))return;
  fetch("/api/cloud/delete/"+n,{method:"DELETE",headers:{Authorization:"Bearer "+S.token}}).then(function(){toast("Supprime");listCloud()});
}

function fmt(b){if(!b)return"0 B";var s=["B","KB","MB","GB"];var i=Math.floor(Math.log(b)/Math.log(1024));return(b/Math.pow(1024,i)).toFixed(1)+" "+s[i]}

