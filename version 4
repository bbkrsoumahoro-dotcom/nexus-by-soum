    users = jload(USERS_FILE)
    if u in users and users[u]["password"] == p:
        token = get_token(u)
        users[u]["token"] = token
        jsave(USERS_FILE, users)
        return jsonify({"success":True, "token":token, "username":u, "role":users[u]["role"]})
    return jsonify({"error":"Identifiants invalides"}), 401

@app.route("/api/register", methods=["POST"])
def register():
    cfg = jload(CONFIG_FILE)
    if not cfg.get("allow_registration", True):
        return jsonify({"error":"Inscriptions fermees"}), 403
    d = request.json
    u, p = d.get("username","").strip(), d.get("password","").strip()
    if not u or not p: return jsonify({"error":"Champs requis"}), 400
    users = jload(USERS_FILE)
