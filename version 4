@app.route("/api/cloud/upload", methods=["POST"])
@require_auth
def cloud_upload():
    if "file" not in request.files:
        return jsonify({"error":"Aucun fichier"}), 400
    f = request.files["file"]
    ud = os.path.join(CLOUD_DIR, request.current_user)
    os.makedirs(ud, exist_ok=True)
    fn = secure_filename(f.filename)
    f.save(os.path.join(ud, fn))
    return jsonify({"success":True, "filename":fn})

@app.route("/api/cloud/list")
@require_auth
def cloud_list():
    ud = os.path.join(CLOUD_DIR, request.current_user)
    if not os.path.exists(ud): return jsonify([])
    files = []
    for f in os.listdir(ud):
        fp = os.path.join(ud, f)
        if os.path.isfile(fp):
            files.append({"name":f, "size":os.path.getsize(fp)})
    return jsonify(files)

@app.route("/api/cloud/download/<filename>")
@require_auth
def cloud_download(filename):
    return send_from_directory(os.path.join(CLOUD_DIR, request.current_user), filename)

@app.route("/api/cloud/delete/<filename>", methods=["DELETE"])
@require_auth
def cloud_delete(filename):
    fp = os.path.join(CLOUD_DIR, request.current_user, secure_filename(filename))
    if os.path.exists(fp): os.remove(fp)
    return jsonify({"success":True})

@app.route("/api/exec", methods=["POST"])
@require_admin
def api_exec():
    d = request.json
    code, lang = d.get("code",""), d.get("lang","python")
    try:
        if lang == "python":
            from io import StringIO
            old = sys.stdout
            sys.stdout = StringIO()
            try:
                exec(code, {"__builtins__":__builtins__}, {})
                out = sys.stdout.getvalue()
            finally:
                sys.stdout = old
            return jsonify({"output":out, "success":True})
        elif lang in ("bash","sh"):
            r = subprocess.run(["bash","-c",code], capture_output=True, text=True, timeout=30)
            return jsonify({"output":r.stdout+r.stderr, "success":r.returncode==0})
        else:
            return jsonify({"error":"Langage non supporte"}), 400
    except subprocess.TimeoutExpired:
        return jsonify({"output":"Timeout (30s)", "success":False})
    except Exception as e:
        return jsonify({"output":str(e), "success":False})

