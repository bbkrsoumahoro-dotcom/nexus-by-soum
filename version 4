if not os.path.exists(MARKET_FILE): jsave(MARKET_FILE, [])
if not os.path.exists(PAY_FILE): jsave(PAY_FILE, [])

def get_token(username):
    return hashlib.sha256(f"{username}:{datetime.now()}:{uuid.uuid4()}".encode()).hexdigest()

def check_auth(token):
    users = jload(USERS_FILE)
    for u, d in users.items():
        if d.get("token") == token: return u, d.get("role", "client")
    return None, None

from functools import wraps
def require_auth(f):
    @wraps(f)
    def d(*a, **kw):
        token = request.headers.get("Authorization","").replace("Bearer ","")
        uname, role = check_auth(token)
        if not uname: return jsonify({"error":"Auth requise"}), 401
        request.current_user = uname
        request.current_role = role
        return f(*a, **kw)
    return d

def require_admin(f):
    @wraps(f)
    @require_auth
    def d(*a, **kw):
        if request.current_role != "admin": return jsonify({"error":"Admin requis"}), 403
        return f(*a, **kw)
    return d

