# ---- TERMINAL (exécution de code) ----
@app.route('/api/terminal/run', methods=['POST'])
@require_auth
def api_run_code():
    data = request.json
    code = data.get('code', '').strip()
    
    if not code:
        return jsonify({"error": "Code vide"}), 400
    
    # Exécution sécurisée (sandboxé)
    try:
        import sys
        from io import StringIO
        
        # Capturer la sortie
        old_stdout = sys.stdout
        old_stderr = sys.stderr
        sys.stdout = StringIO()
        sys.stderr = StringIO()
        
        # Exécuter le code
        exec_globals = {
            "__builtins__": __builtins__,
            "print": print,
            "len": len,
            "str": str,
            "int": int,
            "float": float,
            "list": list,
            "dict": dict,
            "range": range,
            "sum": sum,
            "min": min,
            "max": max,
            "sorted": sorted,
            "reversed": reversed,
            "enumerate": enumerate,
            "zip": zip,
            "map": map,
            "filter": filter,
            "any": any,
            "all": all,
            "datetime": datetime,
            "time": time,
            "json": json,
            "math": __import__('math'),
            "random": __import__('random'),
            "os": __import__('os'),
            "requests": __import__('requests'),
        }
        
        try:
            exec(code, exec_globals)
            output = sys.stdout.getvalue()
            error = sys.stderr.getvalue()
        except Exception as e:
            output = sys.stdout.getvalue()
            error = str(e)
        
        sys.stdout = old_stdout
        sys.stderr = old_stderr
        
        return jsonify({
            "success": True,
            "output": output if output else "✅ Code exécuté sans erreur",
            "error": error if error else None
        })
    except Exception as e:
        return jsonify({
            "success": False,
            "error": str(e)
        })

