@app.route('/api/auth/login', methods=['POST'])
def api_login():
    data = request.json
    username = data.get('username', '').strip()
    password = data.get('password', '').strip()
    
    users = get_users()
    for user in users:
        if user['username'] == username and user['password'] == password:
            # Générer un token
            token = hashlib.sha256(f"{username}:{password}:{time.time()}".encode()).hexdigest()[:32]
            user['token'] = token
            user['last_login'] = datetime.datetime.now().isoformat()
            save_users(users)
            
            return jsonify({
                "success": True,
                "token": token,
                "user": {
                    "id": user['id'],
                    "username": user['username'],
                    "name": user['name'],
                    "role": user['role'],
                    "email": user.get('email', '')
                }
            })
    
    return jsonify({"error": "Identifiants incorrects"}), 401

@app.route('/api/auth/register', methods=['POST'])
def api_register():
    settings = get_settings()
    if not settings.get("allow_registration", True):
        return jsonify({"error": "Inscriptions désactivées"}), 403
    
    data = request.json
    username = data.get('username', '').strip()
    password = data.get('password', '').strip()
    name = data.get('name', username)
    
    if not username or not password:
        return jsonify({"error": "Champs requis"}), 400
    
    users = get_users()
    if any(u['username'] == username for u in users):
        return jsonify({"error": "Utilisateur existe déjà"}), 409
    
    new_user = {
        "id": str(uuid.uuid4()),
        "username": username,
        "password": password,
        "role": settings.get("default_user_role", "client"),
        "name": name,
        "email": data.get('email', ''),
        "created": datetime.datetime.now().isoformat(),
        "permissions": ["read", "download", "stream"]
    }
    
    token = hashlib.sha256(f"{username}:{password}:{time.time()}".encode()).hexdigest()[:32]
    new_user['token'] = token
    users.append(new_user)
    save_users(users)
    
    return jsonify({
        "success": True,
        "token": token,
        "user": {
            "id": new_user['id'],
            "username": new_user['username'],
            "name": new_user['name'],
            "role": new_user['role']
        }
    })

