            import requests as req
            resp = req.get(extension['url'], timeout=10)
            ext_name = f"ext_{extension['id']}.html"
            ext_path = EXTENSIONS_DIR / ext_name
            with open(ext_path, 'w', encoding='utf-8') as f:
                f.write(resp.text)
            extension['path'] = f"/extensions/{ext_name}"
        except:
            extension['path'] = extension['url']
    elif extension.get('type') == 'code':
        ext_name = f"ext_{extension['id']}.html"
        ext_path = EXTENSIONS_DIR / ext_name
        with open(ext_path, 'w', encoding='utf-8') as f:
            f.write(extension.get('code', ''))
        extension['path'] = f"/extensions/{ext_name}"
    
    extensions.append(extension)
    settings['extensions'] = extensions
    save_settings(settings)
    return jsonify({"success": True, "extension": extension}), 201

@app.route('/extensions/<filename>')
def api_serve_extension(filename):
    return send_from_directory(str(EXTENSIONS_DIR), filename)

