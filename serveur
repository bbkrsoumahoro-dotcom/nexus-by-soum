def find_user(token):
    """Trouve un utilisateur par token d'authentification"""
    users = get_users()
    for u in users:
        if u.get("token") == token:
            return u
    return None

def require_auth(f):
    """Décorateur pour les routes nécessitant une authentification"""
    def wrapper(*args, **kwargs):
        token = request.headers.get('Authorization', '').replace('Bearer ', '')
        user = find_user(token)
        if not user:
            return jsonify({"error": "Non authentifié", "code": "AUTH_REQUIRED"}), 401
        request.current_user = user
        return f(*args, **kwargs)
    wrapper.__name__ = f.__name__
    return wrapper

def require_admin(f):
    """Décorateur pour les routes admin"""
    def wrapper(*args, **kwargs):
        token = request.headers.get('Authorization', '').replace('Bearer ', '')
        user = find_user(token)
        if not user:
            return jsonify({"error": "Non authentifié"}), 401
        if user.get("role") not in ["admin", "superadmin"]:
            return jsonify({"error": "Accès refusé - Admin seulement"}), 403
        request.current_user = user
        return f(*args, **kwargs)
    wrapper.__name__ = f.__name__
    return wrapper

