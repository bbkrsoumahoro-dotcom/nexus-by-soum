def api_download_torrent():
    data = request.json
    magnet = data.get('magnet', '')
    if not magnet:
        return jsonify({"error": "Magnet requis"}), 400
    
    # Téléchargement via qBittorrent
    settings = get_settings()
    qb_host = settings.get('qb_host', 'http://localhost:8080')
    
    try:
        import requests as req
        # Connexion à qBittorrent
        login_resp = req.post(f"{qb_host}/api/v2/auth/login", 
                            data={"username": settings['qb_user'], "password": settings['qb_pass']})
        if login_resp.status_code == 200:
            cookie = login_resp.headers.get('Set-Cookie', '')
            # Ajouter le torrent
            add_resp = req.post(f"{qb_host}/api/v2/torrents/add",
                              headers={"Cookie": cookie},
                              data={"urls": magnet})
            return jsonify({"success": True, "message": "Torrent ajouté à qBittorrent"})
        else:
            return jsonify({"success": True, "message": "Magnet copié (qBittorrent non connecté)"})
    except:
        return jsonify({"success": True, "message": "Lien magnet prêt. Collez-le dans qBittorrent."})

