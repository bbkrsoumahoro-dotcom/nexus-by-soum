@app.route('/api/cloud/upload', methods=['POST'])
@require_auth
def api_cloud_upload():
    if 'file' not in request.files:
        return jsonify({"error": "Aucun fichier"}), 400
    
    files = request.files.getlist('file')
    cloud = get_cloud()
    
    for file in files:
        if file.filename:
            filename = secure_filename(file.filename)
            filepath = CLOUD_DIR / filename
            file.save(str(filepath))
            
            size = filepath.stat().st_size
            size_str = f"{size/1024/1024:.1f} Mo" if size > 1024*1024 else f"{size/1024:.1f} Ko"
            
            ext = filename.split('.')[-1].lower() if '.' in filename else ''
            icon_map = {
                'pdf': 'fa-file-pdf', 'zip': 'fa-file-archive', 'rar': 'fa-file-archive',
                'mp4': 'fa-video', 'avi': 'fa-video', 'mkv': 'fa-video', 'webm': 'fa-video',
                'jpg': 'fa-image', 'png': 'fa-image', 'gif': 'fa-image',
                'py': 'fa-file-code', 'js': 'fa-file-code', 'html': 'fa-file-code',
                'mp3': 'fa-music', 'wav': 'fa-music', 'flac': 'fa-music'
            }
            
            cloud.append({
                "name": filename,
                "type": "file",
                "size": size_str,
                "icon": icon_map.get(ext, 'fa-file'),
                "color": "#0088ff" if ext in ['mp4','avi','mkv','webm'] else "#00ffc8",
                "path": f"/cloud/{filename}",
                "added": datetime.datetime.now().isoformat()
            })
    
    save_cloud(cloud)
    return jsonify({"success": True, "files": cloud})

